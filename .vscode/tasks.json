{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Project: Build",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build.py", "build"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Project: Build + Test + Extension",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build.py", "check"],
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Project: Clean",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build.py", "clean"],
      "problemMatcher": []
    },
    {
      "label": "Project: Clean All",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build.py", "clean", "--all"],
      "problemMatcher": []
    },
    {
      "label": "Project: Build Extension (.vsix)",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build.py", "extension"],
      "problemMatcher": []
    },
    {
      "label": "Project: Run Tests (CTest)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "gcc-debug-static-x86_64", "--target", "test"],
      "group": "test"
    },
    {
      "label": "Project: Generate Coverage Report",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "gcc-debug-static-x86_64", "--target", "coverage_report"],
      "dependsOn": ["Project: Run Tests (CTest)"]
    },
    {
      "label": "Project: Package (CPack)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "gcc-debug-static-x86_64", "--target", "package"]
    },
    {
      "label": "Project: Remote Deploy",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/build.py", "deploy",
        "--host", "${input:remoteHost}",
        "--path", "${input:remotePath}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "remoteHost",
      "type": "promptString",
      "description": "Remote host (user@host)",
      "default": "user@remote-ip"
    },
    {
      "id": "remotePath",
      "type": "promptString",
      "description": "Remote target path",
      "default": "/tmp/cpp_project"
    }
  ]
}
