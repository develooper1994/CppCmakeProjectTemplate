root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,h,hpp,cc,cxx,c,h.in}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[CMakeLists.txt, *.cmake]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 8
