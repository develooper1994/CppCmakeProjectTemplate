# ════════════════════════════════════════════════════════════════════════════════
# CppCmakeProjectTemplate — EditorConfig
# ════════════════════════════════════════════════════════════════════════════════
# https://editorconfig.org
#
# Standardize editor settings across the project.
# Supported by VS, VS Code, CLion, Vim, Emacs and other editors.
# ════════════════════════════════════════════════════════════════════════════════

root = true

# ── Genel ────────────────────────────────────────────────────────────────────
[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ── C / C++ ──────────────────────────────────────────────────────────────────
[*.{h,hpp,c,cc,cxx,cpp,in,inl}]
indent_style = tab
indent_size = 4
tab_width = 4

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ── YAML / JSON ─────────────────────────────────────────────────────────────
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# ── Visual Studio project files ────────────────────────────────────────────
[*.{sln,vcxproj,vcxproj.filters,props}]
indent_style = space
indent_size = 2
end_of_line = crlf

# ── CMake ────────────────────────────────────────────────────────────────────
[CMakeLists.txt, *.cmake]
indent_style = space
indent_size = 4

# ── Makefile ─────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
indent_size = 8

