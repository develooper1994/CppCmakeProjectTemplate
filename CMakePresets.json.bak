    },
    {
      "name": "msvc-debug-dynamic-x64",
      "configurePreset": "msvc-debug-dynamic-x64",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release-static-x64",
      "configurePreset": "msvc-release-static-x64",
