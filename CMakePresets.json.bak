{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENABLE_UNIT_TESTS": "ON"
      }
    },
    {
      "name": "unix-base",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "condition": {
        "type": "anyOf",
        "conditions": [
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Linux"
          },
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Darwin"
          }
        ]
      }
    },
    {
      "name": "linux-gcc-base",
      "hidden": true,
      "inherits": "unix-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "clang-base",
      "hidden": true,
      "inherits": "unix-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "win-base",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "gcc-debug-static-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "gcc-debug-dynamic-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "gcc-release-static-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "gcc-release-dynamic-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "gcc-relwithdebinfo-static-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "gcc-relwithdebinfo-dynamic-x86_64",
      "inherits": "linux-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "linux-x86-gcc-base",
      "hidden": true,
      "inherits": "linux-gcc-base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x86.cmake"
    },
    {
      "name": "linux-x86-clang-base",
      "hidden": true,
      "inherits": "clang-base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x86.cmake"
    },
    {
      "name": "gcc-debug-static-x86",
      "inherits": "linux-x86-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "gcc-debug-dynamic-x86",
      "inherits": "linux-x86-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "gcc-release-static-x86",
      "inherits": "linux-x86-gcc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "clang-debug-static-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "clang-debug-dynamic-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "clang-release-static-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "clang-release-dynamic-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "clang-relwithdebinfo-static-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "clang-relwithdebinfo-dynamic-x86_64",
      "inherits": "clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "clang-debug-static-x86",
      "inherits": "linux-x86-clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-debug-static-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-debug-dynamic-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "msvc-release-static-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-release-dynamic-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "msvc-relwithdebinfo-static-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-relwithdebinfo-dynamic-x64",
      "inherits": "win-base",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "msvc-debug-static-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-debug-dynamic-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "msvc-release-static-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-release-dynamic-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "msvc-relwithdebinfo-static-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "msvc-relwithdebinfo-dynamic-x86",
      "inherits": "win-base",
      "architecture": "win32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "embedded-arm-none-eabi",
      "displayName": "Embedded: ARM Cortex-M4",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_UNIT_TESTS": "OFF"
      }
    },
    {
      "name": "embedded-cortex-m0",
      "displayName": "Embedded: ARM Cortex-M0+",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-cortex-m0.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "ENABLE_UNIT_TESTS": "OFF",
        "ENABLE_LTO": "ON"
      }
    },
    {
      "name": "embedded-cortex-m4",
      "displayName": "Embedded: ARM Cortex-M4F (alias for arm-none-eabi)",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "ENABLE_UNIT_TESTS": "OFF",
        "ENABLE_LTO": "ON"
      }
    },
    {
      "name": "embedded-cortex-m7",
      "displayName": "Embedded: ARM Cortex-M7 (FPv5)",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-cortex-m7.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_UNIT_TESTS": "OFF",
        "ENABLE_LTO": "ON"
      }
    },
    {
      "name": "gcc-debug-static-aarch64",
      "displayName": "GCC Debug Static: AArch64 Linux (cross)",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF",
        "ENABLE_UNIT_TESTS": "OFF"
      }
    },
    {
      "name": "gcc-release-static-aarch64",
      "displayName": "GCC Release Static: AArch64 Linux (cross)",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF",
        "ENABLE_UNIT_TESTS": "OFF",
        "ENABLE_LTO": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-debug-static-x86_64",
      "configurePreset": "gcc-debug-static-x86_64"
    },
    {
      "name": "gcc-debug-dynamic-x86_64",
      "configurePreset": "gcc-debug-dynamic-x86_64"
    },
    {
      "name": "gcc-release-static-x86_64",
      "configurePreset": "gcc-release-static-x86_64"
    },
    {
      "name": "gcc-release-dynamic-x86_64",
      "configurePreset": "gcc-release-dynamic-x86_64"
    },
    {
      "name": "gcc-relwithdebinfo-static-x86_64",
      "configurePreset": "gcc-relwithdebinfo-static-x86_64"
    },
    {
      "name": "gcc-relwithdebinfo-dynamic-x86_64",
      "configurePreset": "gcc-relwithdebinfo-dynamic-x86_64"
    },
    {
      "name": "gcc-debug-static-x86",
      "configurePreset": "gcc-debug-static-x86"
    },
    {
      "name": "gcc-debug-dynamic-x86",
      "configurePreset": "gcc-debug-dynamic-x86"
    },
    {
      "name": "gcc-release-static-x86",
      "configurePreset": "gcc-release-static-x86"
    },
