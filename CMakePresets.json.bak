    },
    {
      "name": "msvc-relwithdebinfo-static-x86",
      "configurePreset": "msvc-relwithdebinfo-static-x86",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "msvc-relwithdebinfo-dynamic-x86",
      "configurePreset": "msvc-relwithdebinfo-dynamic-x86",
