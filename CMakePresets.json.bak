    },
    {
      "name": "embedded-arm-none-eabi",
      "configurePreset": "embedded-arm-none-eabi"
    }
  ],
  "testPresets": [
    {
      "name": "base-test",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "gcc-debug-static-x86_64",
      "inherits": "base-test",
      "configurePreset": "gcc-debug-static-x86_64"
    },
    {
      "name": "gcc-release-static-x86_64",
      "inherits": "base-test",
      "configurePreset": "gcc-release-static-x86_64"
    },
    {
      "name": "clang-debug-static-x86_64",
      "inherits": "base-test",
      "configurePreset": "clang-debug-static-x86_64"
    },
    {
      "name": "clang-release-static-x86_64",
      "inherits": "base-test",
      "configurePreset": "clang-release-static-x86_64"
    },
    {
      "name": "msvc-debug-static-x64",
      "inherits": "base-test",
      "configurePreset": "msvc-debug-static-x64",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release-static-x64",
      "inherits": "base-test",
      "configurePreset": "msvc-release-static-x64",
      "configuration": "Release"
    }
  ]
