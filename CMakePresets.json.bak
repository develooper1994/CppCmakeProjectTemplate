      "configurePreset": "clang-debug-dynamic-x86_64"
    },
    {
      "name": "clang-release-static-x86_64",
      "configurePreset": "clang-release-static-x86_64"
    },
    {
      "name": "clang-release-dynamic-x86_64",
      "configurePreset": "clang-release-dynamic-x86_64"
    },
    {
      "name": "clang-relwithdebinfo-static-x86_64",
      "configurePreset": "clang-relwithdebinfo-static-x86_64"
    },
    {
      "name": "clang-relwithdebinfo-dynamic-x86_64",
      "configurePreset": "clang-relwithdebinfo-dynamic-x86_64"
    },
    {
      "name": "clang-debug-static-x86",
      "configurePreset": "clang-debug-static-x86"
    },
    {
