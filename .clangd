# .clangd — generated by: python3 scripts/tool.py sol clangd
# Regenerate at any time; the file is safe to commit.

CompileFlags:
  CompilationDatabase: /home/developer/Projects/github/CppCmakeProjectTemplate
  Add: [-Wno-unknown-warning-option]

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  BlockEnd: No

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - modernize*
      - performance*
      - readability*
    Remove:
      - readability-magic-numbers
      - modernize-use-trailing-return-type
