constexpr std::string_view compiler_id = "@CMAKE_CXX_COMPILER_ID@";
constexpr std::string_view compiler_version = "@CMAKE_CXX_COMPILER_VERSION@";
constexpr std::string_view architecture = "@PROJECT_ARCH@";
constexpr std::string_view build_timestamp = "@BUILD_TIMESTAMP@";
constexpr std::string_view cmake_version = "@CMAKE_VERSION@";
constexpr std::string_view library_type = "@LIB_TYPE_STR@"; // Static or Shared

