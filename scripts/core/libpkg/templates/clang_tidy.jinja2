---
# .clang-tidy — Generated for profile: {{ profile }}
# DO NOT EDIT MANUALLY — Generated by tool build

Checks: >
    clang-diagnostic-*,
    clang-analyzer-*,
    bugprone-*,
    cert-*,
    {% if profile in ['strict', 'hardened', 'extreme'] %}
    cppcoreguidelines-*,
    {% endif %}
    modernize-*,
    performance-*,
    readability-*,
    -cppcoreguidelines-avoid-magic-numbers,
    {% if profile != 'extreme' %}
    -cppcoreguidelines-owning-memory,
    -cppcoreguidelines-pro-type-member-init,
    -cppcoreguidelines-no-malloc,
    -cppcoreguidelines-avoid-c-arrays,
    {% endif %}
    -readability-magic-numbers,
    -modernize-use-trailing-return-type,
    -google-readability-todo

WarningsAsErrors: "{{ "*" if profile in ['hardened', 'extreme'] else "" }}"

HeaderFilterRegex: '^(libs|apps)/.*\.(h|hpp)$'

FormatStyle: file

CheckOptions:
    - key: readability-identifier-naming.NamespaceCase
      value: lower_case
    - key: readability-identifier-naming.ClassCase
      value: CamelCase
    - key: readability-identifier-naming.StructCase
      value: CamelCase
    - key: readability-identifier-naming.FunctionCase
      value: lower_case
    - key: readability-identifier-naming.VariableCase
      value: lower_case
    - key: readability-identifier-naming.ParameterCase
      value: lower_case
    - key: readability-identifier-naming.MemberCase
      value: lower_case
    - key: readability-identifier-naming.PrivateMemberPrefix
      value: m_
    - key: readability-identifier-naming.EnumConstantCase
      value: CamelCase
    - key: readability-identifier-naming.ConstantCase
      value: UPPER_CASE
    - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
      value: true
    - key: modernize-use-default-member-init.UseAssignment
      value: false
