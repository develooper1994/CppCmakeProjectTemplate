{% set cls = name.capitalize() %}
#include "{{ name }}/{{ name }}.h"
#include <memory>

{% if namespace %}
namespace {{ namespace }} {

struct Impl : I{{ cls }} { void run() override { /* noop */ } };
std::unique_ptr<I{{ cls }}> make_{{ name }}() { return std::make_unique<Impl>(); }

} // namespace {{ namespace }}
{% else %}
struct Impl : I{{ cls }} { void run() override { /* noop */ } };
std::unique_ptr<I{{ cls }}> make_{{ name }}() { return std::make_unique<Impl>(); }
{% endif %}
